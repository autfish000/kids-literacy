/* ===================== 全局样式 ===================== */
page {
  --mlp-pink: #ff4fa3;
  --mlp-purple: #9b4de0;
  --mlp-blue: #4a8bff;
  --mlp-yellow: #ffd23f;
  --mlp-green: #7fd96b;
  --tianzi-color: #ff9fc7;
  --text-dark: #4a2860;

  margin: 0;
  padding: 0;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  box-sizing: border-box;
  background: linear-gradient(160deg, #fff5fa 0%, #fbeaff 50%, #eef5ff 100%);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: var(--text-dark);
}

/* ===================== 应用容器 ===================== */
.app {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* ===================== 顶部标题 ===================== */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20px 20px 0;
  z-index: 5;
  text-align: center;
}

.title {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
}

.title-text {
  font-size: 32px;
  font-weight: 700;
  letter-spacing: 6px;
  background: linear-gradient(135deg, #ff4fa3 0%, #9b4de0 40%, #4a8bff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  font-family: "Comic Sans MS", "Hiragino Maru Gothic ProN", "华文圆体", cursive, sans-serif;
}

.sparkle {
  font-size: 18px;
  color: #ff4fa3;
  animation: twinkle 2.4s ease-in-out infinite;
}

.sparkle:last-child {
  color: #9b4de0;
  animation-delay: 1.2s;
}

@keyframes twinkle {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 1; }
  50% { transform: scale(1.3) rotate(20deg); opacity: 0.6; }
}

/* ===================== 卡片区域 ===================== */
.stage {
  position: absolute;
  top: 64px;
  left: 0;
  right: 0;
  bottom: 100px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  z-index: 2;
}

.card-stack {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* ===================== 识字卡片 ===================== */
.card {
  width: 100%;
  background: linear-gradient(180deg, #fffafc 0%, #fdf2ff 100%);
  border-radius: 24px;
  box-shadow:
    0 6rpx 20rpx rgba(155, 77, 224, 0.18),
    0 2rpx 4rpx rgba(255, 79, 163, 0.12),
    inset 0 0 30rpx rgba(255, 159, 199, 0.12);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

/* ===================== 拼音格 ===================== */
.pinyin-box {
  background: #ffffff;
  border: 4rpx solid var(--tianzi-color);
  border-radius: 28rpx;
  padding: 24rpx 32rpx;
  margin: 24rpx 24rpx 0 24rpx;
  text-align: center;
  font-size: 56rpx;
  font-weight: 500;
  color: #9b4de0;
  letter-spacing: 8rpx;
  font-family: "Roboto", sans-serif;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 79, 163, 0.12);
  box-sizing: border-box;
}

/* 拼音格双虚线 */
.pinyin-box::before,
.pinyin-box::after {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  border-top: 2rpx dashed var(--tianzi-color);
  pointer-events: none;
}

.pinyin-box::before { top: 33%; }
.pinyin-box::after  { top: 66%; }

/* ===================== 田字格 ===================== */
.tianzi {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 24rpx 24rpx 0 24rpx;
}

.tianzi-grid {
  position: relative;
  aspect-ratio: 1 / 1;
  width: 100%;
  max-width: 520rpx;
  background: #ffffff;
  border: 4rpx solid var(--tianzi-color);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(255, 79, 163, 0.15);
  box-sizing: border-box;
  overflow: hidden;
}

/* 田字格横竖虚线 */
.tianzi-grid::before,
.tianzi-grid::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.tianzi-grid::before {
  left: 0;
  right: 0;
  top: 50%;
  border-top: 2rpx dashed var(--tianzi-color);
}

.tianzi-grid::after {
  top: 0;
  bottom: 0;
  left: 50%;
  border-left: 2rpx dashed var(--tianzi-color);
}

/* 汉字 */
.hanzi {
  font-family: "KaiTi", "楷体", "STKaiti", "华文楷体", serif;
  font-weight: 400;
  font-size: 320rpx;
  color: #3a1f5c;
  text-align: center;
  line-height: 1;
  position: relative;
  z-index: 2;
}

/* ===================== 组词 ===================== */
.cizu-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 24rpx 24rpx 24rpx 24rpx;
  padding-bottom: 8rpx;
}

.cizu-word {
  flex: 1;
  font-family: "KaiTi", "楷体", "STKaiti", "华文楷体", serif;
  font-size: 40rpx;
  color: #4a2860;
  letter-spacing: 4rpx;
  font-weight: 600;
}

.cizu-left {
  text-align: left;
}

.cizu-center {
  text-align: center;
}

.cizu-right {
  text-align: right;
}

/* ===================== 边界提示 ===================== */
.card-bg-hint {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #9b4de0;
  border-radius: 24px;
  text-align: center;
  padding: 0 48rpx;
  z-index: 3;
  background: rgba(255, 250, 252, 0.96);
}

.bg-arrow { font-size: 96rpx; }
.bg-title { font-size: 40rpx; }
.bg-sub { font-size: 26rpx; opacity: 0.7; }

/* ===================== 底部进度条 ===================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 40rpx 40rpx;
  z-index: 5;
}

.progress-wrap {
  max-width: 800rpx;
  margin: 0 auto;
  background: rgba(255, 250, 252, 0.85);
  border-radius: 36rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(155, 77, 224, 0.15);
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 700;
  color: #9b4de0;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.progress-bar {
  position: relative;
  height: 32rpx;
  background: #f5e8ff;
  border-radius: 36rpx;
  overflow: visible;
}

.progress-fill {
  position: relative;
  height: 100%;
  background: linear-gradient(90deg, #ff4fa3 0%, #9b4de0 50%, #4a8bff 100%);
  border-radius: 36rpx;
  transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 0 16rpx rgba(255, 79, 163, 0.35);
  overflow: visible;
}

.progress-unicorn {
  position: absolute;
  right: -24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 6rpx rgba(155, 77, 224, 0.4));
  animation: ponyRun 0.5s ease-in-out infinite alternate;
}

@keyframes ponyRun {
  from { transform: translateY(-50%) translateX(0) rotate(-5deg); }
  to   { transform: translateY(-58%) translateX(2rpx) rotate(8deg); }
}
