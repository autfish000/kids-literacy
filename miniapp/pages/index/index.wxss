/* ===================== 全局样式 ===================== */
page {
  margin: 0;
  padding: 0;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  box-sizing: border-box;
  background: linear-gradient(160deg, #fff5fa 0%, #fbeaff 50%, #eef5ff 100%);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #4a2860;
}

page::after {
  content: "";
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220' viewBox='0 0 220 220'><text x='10' y='28' font-size='18' fill='%23ffd23f' opacity='0.25'>★</text><text x='160' y='40' font-size='14' fill='%23ff4fa3' opacity='0.22'>✦</text><text x='100' y='60' font-size='12' fill='%239b4de0' opacity='0.20'>◆</text><text x='40' y='100' font-size='16' fill='%234a8bff' opacity='0.22'>♡</text><text x='180' y='120' font-size='14' fill='%23ff9fc7' opacity='0.22'>✦</text><text x='120' y='140' font-size='16' fill='%237fd96b' opacity='0.20'>★</text><text x='20' y='170' font-size='14' fill='%23c9a5ff' opacity='0.22'>◆</text><text x='150' y='180' font-size='12' fill='%23ffd23f' opacity='0.25'>♡</text><text x='70' y='200' font-size='14' fill='%234a8bff' opacity='0.22'>✦</text></svg>");
  background-repeat: repeat;
  background-size: 220px 220px;
  pointer-events: none;
  z-index: 0;
}

/* ===================== 应用容器 ===================== */
.app {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  z-index: 1;
}

/* ===================== 内容区域：标题 + 卡片 + 进度条 ===================== */
.content-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 60rpx 50px;
  box-sizing: border-box;
}

/* ===================== 页面标题 ===================== */
.page-title {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30px;
}

.title-text {
  font-size: 36px;
  font-weight: 400;
  letter-spacing: 6px;
  background: linear-gradient(135deg, #ff4fa3 0%, #9b4de0 40%, #4a8bff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  font-family: "PingFang SC", "苹方-简", "Hiragino Sans GB", sans-serif;
}

/* ===================== 识字卡片 ===================== */
.card {
  position: relative;
  width: 100%;
  background: linear-gradient(180deg, #fffafc 0%, #fdf2ff 100%);
  border-radius: 24px;
  box-shadow:
    0 6rpx 20rpx rgba(155, 77, 224, 0.18),
    0 2rpx 4rpx rgba(255, 79, 163, 0.12),
    inset 0 0 30rpx rgba(255, 159, 199, 0.12);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===================== 拼音格 ===================== */
.pinyin-box {
  background: #ffffff;
  border: 4rpx solid #ff9fc7;
  border-radius: 28rpx;
  padding: 24rpx 0;
  margin: 50px 30px 0 30px;
  text-align: center;
  font-size: 56rpx;
  font-weight: 500;
  color: #9b4de0;
  letter-spacing: 8rpx;
  font-family: "Roboto", sans-serif;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 79, 163, 0.12);
  box-sizing: border-box;
}

/* 拼音格双虚线 */
.pinyin-box::before,
.pinyin-box::after {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  border-top: 2rpx dashed #ff9fc7;
  pointer-events: none;
}

.pinyin-box::before { top: 33%; }
.pinyin-box::after  { top: 66%; }

/* ===================== 田字格 ===================== */
.tianzi {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 34rpx 30px 0 30px;
}

.tianzi-grid {
  position: relative;
  aspect-ratio: 1 / 1;
  width: 100%;
  max-width: 520rpx;
  background: #ffffff;
  border: 4rpx solid #ff9fc7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(255, 79, 163, 0.15);
  box-sizing: border-box;
  overflow: hidden;
}

/* 田字格横竖虚线 */
.tianzi-grid::before,
.tianzi-grid::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.tianzi-grid::before {
  left: 0;
  right: 0;
  top: 50%;
  border-top: 2rpx dashed #ff9fc7;
}

.tianzi-grid::after {
  top: 0;
  bottom: 0;
  left: 50%;
  border-left: 2rpx dashed #ff9fc7;
}

/* 汉字 */
.hanzi {
  font-family: "KaiTi", "楷体", "STKaiti", "华文楷体", serif;
  font-weight: 400;
  font-size: 320rpx;
  color: #3a1f5c;
  text-align: center;
  line-height: 1;
  position: relative;
  z-index: 2;
}

/* ===================== 组词 ===================== */
.cizu-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 34rpx 30px 50px 30px;
}

.cizu-item {
  flex: 1;
  text-align: center;
  padding: 8rpx 4rpx;
  border-radius: 8rpx;
  background: rgba(255, 159, 199, 0.15);
}

.cizu-word {
  font-family: "KaiTi", "楷体", "STKaiti", "华文楷体", serif;
  font-size: 36rpx;
  color: #4a2860;
  letter-spacing: 4rpx;
  font-weight: 600;
}

/* ===================== 滑动透明覆盖层 ===================== */
.card-overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
}

/* ===================== 边界提示 ===================== */
.card-bg-hint {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #9b4de0;
  border-radius: 24px;
  text-align: center;
  padding: 0 48rpx;
  z-index: 3;
  background: rgba(255, 250, 252, 0.96);
}

.bg-arrow { font-size: 96rpx; }
.bg-title { font-size: 40rpx; }
.bg-sub { font-size: 26rpx; opacity: 0.7; }

/* ===================== 底部进度条 ===================== */
.progress-wrap {
  width: 100%;
  max-width: 700rpx;
  margin-top: 30px;
  background: rgba(255, 250, 252, 0.85);
  border-radius: 36rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(155, 77, 224, 0.15);
  box-sizing: border-box;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 700;
  color: #9b4de0;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.progress-bar {
  position: relative;
  height: 32rpx;
  background: #f5e8ff;
  border-radius: 36rpx;
  overflow: visible;
}

.progress-fill {
  position: relative;
  height: 100%;
  background: linear-gradient(90deg, #ff4fa3 0%, #9b4de0 50%, #4a8bff 100%);
  border-radius: 36rpx;
  transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 0 16rpx rgba(255, 79, 163, 0.35);
  overflow: visible;
}

.progress-unicorn {
  position: absolute;
  right: -24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 6rpx rgba(155, 77, 224, 0.4));
  animation: ponyRun 0.5s ease-in-out infinite alternate;
}

@keyframes ponyRun {
  from { transform: translateY(-50%) translateX(0) rotate(-5deg); }
  to   { transform: translateY(-58%) translateX(2rpx) rotate(8deg); }
}
