<view class="app">
  <!-- 卡片区域：标题 + 卡片 + 进度条 -->
  <view class="content-area">
    <!-- 页面标题：用第一个组词造句 -->
    <view class="page-title">
      <text class="title-text">🦄 {{currentWord.sentenceText}}</text>
    </view>

    <!-- 识字卡片 -->
    <view class="card">
      <!-- 拼音格 -->
      <view class="pinyin-box">
        <text class="pinyin-text">{{currentWord.pinyin}}</text>
      </view>

      <!-- 田字格 -->
      <view class="tianzi">
        <view class="tianzi-grid">
          <text class="hanzi">{{currentWord.char}}</text>
        </view>
      </view>

      <!-- 组词 -->
      <view class="cizu-row">
        <view class="cizu-item"><text class="cizu-word">{{cizuWords[0]}}</text></view>
        <view class="cizu-item"><text class="cizu-word">{{cizuWords[1]}}</text></view>
        <view class="cizu-item"><text class="cizu-word">{{cizuWords[2]}}</text></view>
      </view>

      <!-- 滑动触发区 + 边界提示 -->
      <view class="card-overlay"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
      ></view>
      <view class="card-bg-hint" wx:if="{{boundaryDir === 'next' || boundaryDir === 'prev'}}">
        <text class="bg-arrow">{{boundaryDir === 'next' ? '👉' : '👈'}}</text>
        <text class="bg-title">{{boundaryDir === 'next' ? '进入下一组' : '回到上一组'}}</text>
        <text class="bg-sub">{{boundaryDir === 'next' ? '继续向左滑，开启全新5个字' : '继续向右滑，再学一遍'}}</text>
      </view>
    </view>

    <!-- 底部进度条 -->
    <view class="progress-wrap">
      <view class="progress-label">
        <text>第 {{groupIndex + 1}} 组</text>
        <text>{{currentIdx + 1}} / {{currentQueue.length}}</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%;">
          <text class="progress-unicorn">🦄</text>
        </view>
      </view>
    </view>
  </view>
</view>
